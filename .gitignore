# Auto-generated C++ files from CTOT.py (in any subdirectory)
**/parameters.h
**/ctot.cpp
**/grad_ctot.cpp
**/calculate_P.cpp

# Generated Gibbs.dat files that aren't the original Standard_Version/Gibbs.dat
**/Gibbs.dat
!Standard_Version/Gibbs.dat

# Compiled object files and executables (in any subdirectory)
**/*.o
**/solver

# Runtime output files from solver (in any subdirectory)
**/output.dat
**/info.dat
# But track baseline test outputs
!test_baselines/**/output.dat

# Test diff files
**/test_diff_*.txt

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Root-level generated input/output folders (versioned runs)
results*/**

.cursorrules